generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["account", "profile", "global"]
}

model Role {
  id          Int           @id @default(autoincrement())
  description String        @db.VarChar(255)
  level       Int           @db.SmallInt
  dateAdded   DateTime      @default(now()) @map("date_added")
  visible     Int           @default(0) @db.SmallInt
  orderBy     Int           @default(1) @map("order_by") @db.SmallInt
  users       UserAccount[]
  @@map("tbl_role")
  @@schema("account")
}

model UserAccount {
  id          BigInt    @id @default(autoincrement())
  basicInfoId BigInt    @map("basic_info_id")
  roleId      Int    @map("role_id")
  dateAdded   DateTime  @default(now()) @map("date_added")
  dateUpdated DateTime? @map("date_updated")
  username    String    @unique @db.VarChar(255)
  password    String    @db.VarChar(255)
  changePwd   Boolean   @default(true) @map("change_pwd")
  isActive    Boolean   @default(true) @map("is_active")
  addedBy     BigInt?   @map("added_by")
  updatedBy   BigInt?   @map("updated_by")
  role        Role      @relation(fields: [roleId], references: [id])
  basicInfo   BasicInfo @relation(fields: [basicInfoId], references: [id])
  @@unique([basicInfoId, roleId])
  @@map("tbl_useraccount")
  @@schema("account")
}

model BasicInfo {
  id           BigInt        @id @default(autoincrement())
  firstName    String        @map("first_name") @db.VarChar(100)
  middleName   String?       @map("middle_name") @db.VarChar(100)
  lastName     String        @map("last_name") @db.VarChar(100)
  suffix       String?       @db.VarChar(10)
  birthdate    DateTime?     @db.Date
  sex          Boolean
  imgPath      String?       @map("img_path") @db.VarChar(1000)
  uuid         String        @unique @default(uuid()) @db.Uuid
  dateAdded    DateTime?     @default(now()) @map("date_added")
  userAccounts UserAccount[]
  @@map("tbl_basicinfo")
  @@schema("profile")
}

model SchoolYear {
  id          BigInt  @id @default(autoincrement())
  from        Int     @db.SmallInt
  to          Int     @db.SmallInt
  description String  @db.VarChar(255)
  isActive    Boolean @default(true) @map("is_active")
  isLock      Boolean @default(false) @map("is_lock")
  qrtr        Int     @db.SmallInt
  @@map("tbl_sy")
  @@schema("global")
}
